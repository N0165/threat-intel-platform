# Copy this file to ".env" and fill in real values before running the server

# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/threat_intel_db

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# Blockchain (Hardhat local network)
RPC_URL=http://127.0.0.1:8545
# Private key of the admin account (Hardhat account #0 printed by `npx hardhat node`)
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# IPFS (local daemon: `ipfs daemon`, default API port 5001)
IPFS_API_URL=http://127.0.0.1:5001
